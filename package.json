{
  "name": "current-status",
  "version": "1.0.0",
  "description": "",
  "main": "current-status.js",
  "scripts": {
    "start": "browser-sync start --server dist",
    "preview": "browser-sync start --server dist",
    "build": "node assets/scripts/gen-index.js && npm run rss:dist",
    "build:check": "node assets/scripts/gen-index.js --check",
    "build:watch": "node assets/scripts/build-watch.js",
    "date": "npm-run-all date:*",
    "date:short": "node assets/scripts/gen-date-short.js",
    "date:full": "node assets/scripts/gen-date-full.js",
    "rss": "node assets/scripts/gen-rss.js",
    "rss:dist": "node assets/scripts/gen-rss.js dist/rss.xml",
    "test": "npm run test:masto && npm run test:social && npm run test:post && npm run build:check",
    "test:masto": "node assets/scripts/test-masto-publisher.js",
    "test:social": "node assets/scripts/test-social-publisher.js",
    "test:post": "node assets/scripts/test-create-post-from-issue.js",
    "post:from-issue": "node assets/scripts/create-post-from-issue.js",
    "color": "dominant_colours --max-colours=1 --no-palette",
    "deploy": "netlify deploy --prod",
    "masto": "node assets/scripts/masto.js",
    "masto:local": "node assets/scripts/masto-local.js",
    "masto:seed": "node assets/scripts/seed-masto.js",
    "publish:local": "npm run rss && node assets/scripts/publish-local.js",
    "publish:mastodon": "npm run rss && node assets/scripts/publish-mastodon.js",
    "publish:bluesky": "npm run rss && node assets/scripts/bluesky-local.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@atproto/api": "^0.20.6",
    "@netlify/blobs": "^10.7.8",
    "browser-sync": "^3.0.4",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "image-size": "^2.0.2",
    "masto": "^7.11.1",
    "npm-run-all": "^4.1.5",
    "rss": "^1.2.2"
  },
  "volta": {
    "node": "22.11.0"
  },
  "devDependencies": {
    "netlify-cli": "^21.6.0"
  }
}
